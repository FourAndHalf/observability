# Copy this file to .env on the EC2 instance and fill real values.
# Never commit the filled .env file.

# Public HTTPS domains. Point DNS A records to the EC2 public IP first.
OPENOBSERVE_SITE=https://openobserve.yourdomain.com
PHOENIX_SITE=https://phoenix.yourdomain.com
OTEL_SITE=https://otel.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# EC2 production should expose only Caddy publicly.
HTTP_BIND=80
HTTPS_BIND=443

# Keep raw OTLP gRPC private. Prefer HTTPS OTLP through Caddy for remote apps.
OTEL_GRPC_BIND=127.0.0.1
OTEL_HTTP_BIND=127.0.0.1

OPENOBSERVE_ORG=default
OPENOBSERVE_ROOT_EMAIL=admin@yourdomain.com
OPENOBSERVE_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
OPENOBSERVE_LOG_STREAM=app_logs
OPENOBSERVE_TRACE_STREAM=app_traces

# Base64 of "OPENOBSERVE_ROOT_EMAIL:OPENOBSERVE_ROOT_PASSWORD", prefixed with "Basic ".
# Generate:
# printf '%s' 'admin@yourdomain.com:REPLACE_WITH_STRONG_PASSWORD' | base64 -w 0
OPENOBSERVE_AUTH_HEADER=Basic REPLACE_WITH_BASE64_EMAIL_COLON_PASSWORD

# Generate:
# docker run --rm httpd:2.4-alpine htpasswd -nbB otel_ingest 'REPLACE_WITH_INGEST_PASSWORD'
# Escape every "$" as "$$" before saving it here.
OTEL_COLLECTOR_HTPASSWD=otel_ingest:$$2y$$05$$REPLACE_WITH_ESCAPED_HASH

PHOENIX_POSTGRES_USER=phoenix
PHOENIX_POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
PHOENIX_POSTGRES_DB=phoenix
PHOENIX_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Set after first Phoenix login:
# Phoenix -> Settings -> API Keys -> System API Key
PHOENIX_API_KEY=replace-after-creating-phoenix-system-api-key

# S3 backup bucket. Attach an EC2 IAM role instead of storing AWS access keys.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
AWS_S3_BACKUP_URI=s3://your-observability-backup-bucket/observability
AWS_PROFILE=

# Optional OpenObserve S3 storage. Used only with docker-compose.s3.yml.
# Keep these empty if using EBS/local disk for OpenObserve hot data.
OPENOBSERVE_S3_PROVIDER=aws
OPENOBSERVE_S3_BUCKET_NAME=your-openobserve-data-bucket
OPENOBSERVE_S3_REGION_NAME=ap-south-1
