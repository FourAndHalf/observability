{
	auto_https off
}

:80 {
	# Redirect no-trailing-slash requests so they don't fall through to the root handler
	redir /phoenix /phoenix/ 308
	redir /openobserve /openobserve/ 308

	# OTLP HTTP ingest (standard collector paths, no prefix stripping)
	handle /v1/traces {
		reverse_proxy otel-collector:4318
	}
	handle /v1/metrics {
		reverse_proxy otel-collector:4318
	}
	handle /v1/logs {
		reverse_proxy otel-collector:4318
	}

	# Phoenix UI/API. PHOENIX_HOST_ROOT_PATH makes it emit /phoenix-prefixed links,
	# but its static asset server only serves them unprefixed, so strip here.
	handle_path /phoenix/* {
		reverse_proxy phoenix:6006
	}

	# OpenObserve UI/API, kept under /openobserve (ZO_BASE_URI matches)
	handle /openobserve/* {
		reverse_proxy openobserve:5080
	}

	# OTLP collector at the root
	handle {
		reverse_proxy otel-collector:4318
	}
}
