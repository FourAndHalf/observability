# Copy this file to .env before running docker compose.
# Never commit .env. Rotate these values if they are ever shared.

# Public hostnames. For local-only use, set these to localhost subdomains and
# add them to /etc/hosts, or bypass Caddy and use the raw local ports.
# Local/LAN examples use HTTP. For EC2 production, change these to
# https://openobserve.example.com, https://phoenix.example.com, and
# https://otel.example.com after DNS points to the instance.
OPENOBSERVE_SITE=http://openobserve.local
PHOENIX_SITE=http://phoenix.local
OTEL_SITE=http://otel.local
ACME_EMAIL=admin@example.com

# Reverse proxy host ports.
HTTP_BIND=80
HTTPS_BIND=443

# Raw Collector ports. Keep gRPC local by default; expose HTTP OTLP for remote apps.
OTEL_GRPC_BIND=127.0.0.1
OTEL_HTTP_BIND=0.0.0.0

# OpenObserve login and ingestion.
OPENOBSERVE_ORG=default
OPENOBSERVE_ROOT_EMAIL=admin@example.com
OPENOBSERVE_ROOT_PASSWORD=change-me-openobserve-password
OPENOBSERVE_LOG_STREAM=app_logs
OPENOBSERVE_TRACE_STREAM=app_traces

# Base64 of "OPENOBSERVE_ROOT_EMAIL:OPENOBSERVE_ROOT_PASSWORD", prefixed with "Basic ".
# Example: printf '%s' 'admin@example.com:password' | base64
OPENOBSERVE_AUTH_HEADER=Basic REPLACE_WITH_BASE64_EMAIL_COLON_PASSWORD

# Collector ingest auth. Generate with:
# docker run --rm httpd:2.4-alpine htpasswd -nbB otel_ingest 'change-me-ingest-password'
# Important: escape every "$" in the htpasswd output as "$$" before saving it here.
OTEL_COLLECTOR_HTPASSWD=otel_ingest:$$2y$$05$$replace_with_htpasswd_hash

# Phoenix database and login.
PHOENIX_POSTGRES_USER=phoenix
PHOENIX_POSTGRES_PASSWORD=change-me-phoenix-db-password
PHOENIX_POSTGRES_DB=phoenix
PHOENIX_SECRET=replace-with-at-least-32-random-characters-and-1-digit
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=change-me-phoenix-admin-password

# Create this after first Phoenix login: Settings -> API Keys -> System API Key.
# Until this is set, OpenObserve still receives traces, but Phoenix trace export fails.
PHOENIX_API_KEY=replace-after-creating-phoenix-system-api-key

# Backups.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
AWS_S3_BACKUP_URI=s3://replace-with-your-bucket/observability
AWS_PROFILE=default
